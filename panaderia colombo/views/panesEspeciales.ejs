<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="estilos.css">
  <title>Panes especiales</title>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Panadería del Barrio</a>
    </div>
  </nav>

  <main class="container py-5">
    <h1 class="text-center mb-4">Panes especiales</h1>
    <div class="row">
      <div class="col-md-4">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Brioche de vainilla</h5>
            <p class="card-text">Pan suave con cobertura dorada y aroma dulce.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Croissant clásico</h5>
            <p class="card-text">Capas hojaldradas y manteca fresca en cada bocado.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Pan de campo</h5>
            <p class="card-text">Corteza crujiente y miga compacta para acompañar.</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>